// ============================================================
// SabakTutor - Firebase Security Rules
// Safety Lead: Haji Lakhir
// COPPA 2025 Compliant
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────
    // HELPER FUNCTIONS
    // ─────────────────────────────────────────

    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the requesting user owns this document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // COPPA GATE: No data can be written until parental_consent = true
    // This is the core COPPA 2025 requirement for mixed-audience apps
    function hasParentalConsent(userId) {
      return exists(/databases/$(database)/documents/users/$(userId))
        && get(/databases/$(database)/documents/users/$(userId)).data.parental_consent == true;
    }

    // Check if the user is a verified parent
    function isVerifiedParent(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role == 'parent'
        && get(/databases/$(database)/documents/users/$(userId)).data.parent_verified == true;
    }

    // Ensure no real PII fields are being written (COPPA Data Minimization)
    function hasNoPII() {
      return !('real_name' in request.resource.data)
        && !('phone_number' in request.resource.data)
        && !('street_address' in request.resource.data)
        && !('voice_recording_url' in request.resource.data)
        && !('biometric_data' in request.resource.data)
        && !('exact_location' in request.resource.data);
    }

    // ─────────────────────────────────────────
    // /users/{userId}
    // Stores anonymous profile and consent flag
    // ─────────────────────────────────────────
    match /users/{userId} {

      // A user can read their own profile only
      allow read: if isAuthenticated() && isOwner(userId);

      // Creating a new user: only allow safe fields, no PII
      allow create: if isAuthenticated()
        && isOwner(userId)
        && hasNoPII()
        && request.resource.data.keys().hasOnly([
            'uid', 'role', 'grade', 'city',
            'parental_consent', 'parent_verified',
            'created_at', 'xp', 'streak'
           ]);

      // Updating: block any attempt to add PII later
      allow update: if isAuthenticated()
        && isOwner(userId)
        && hasNoPII();

      // COPPA: Parent can delete ALL child data with a single action
      allow delete: if isAuthenticated()
        && (isOwner(userId) || isVerifiedParent(request.auth.uid));
    }

    // ─────────────────────────────────────────
    // /users/{userId}/quiz_sessions/{sessionId}
    // AI quiz logs — BLOCKED until parental consent is given
    // ─────────────────────────────────────────
    match /users/{userId}/quiz_sessions/{sessionId} {

      // Student reads own sessions; parent can read child's sessions
      allow read: if isAuthenticated()
        && (isOwner(userId) || isVerifiedParent(request.auth.uid));

      // COPPA GATE — consent must be true before any AI data is stored
      allow create, update: if isAuthenticated()
        && isOwner(userId)
        && hasParentalConsent(userId)
        && hasNoPII();

      // Student or parent can delete session data
      allow delete: if isAuthenticated()
        && (isOwner(userId) || isVerifiedParent(request.auth.uid));
    }

    // ─────────────────────────────────────────
    // /users/{userId}/progress/{chapterId}
    // Learning progress tracking
    // ─────────────────────────────────────────
    match /users/{userId}/progress/{chapterId} {

      allow read: if isAuthenticated()
        && (isOwner(userId) || isVerifiedParent(request.auth.uid));

      // COPPA GATE applies here as well
      allow write: if isAuthenticated()
        && isOwner(userId)
        && hasParentalConsent(userId)
        && hasNoPII();

      allow delete: if isAuthenticated()
        && (isOwner(userId) || isVerifiedParent(request.auth.uid));
    }

    // ─────────────────────────────────────────
    // /parental_consents/{consentId}
    // Stores Verifiable Parental Consent (VPC) records
    // ─────────────────────────────────────────
    match /parental_consents/{consentId} {

      // Only the parent who created this consent record can read it
      allow read: if isAuthenticated()
        && request.auth.uid == resource.data.parent_uid;

      // Allow creation of a new consent record with required fields only
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasOnly([
            'parent_uid', 'child_uid', 'consent_method',
            'consent_timestamp', 'consent_version', 'is_active'
           ])
        && request.resource.data.consent_version == '2025-06';

      // Parent can revoke (set is_active = false) or fully delete the record
      allow update, delete: if isAuthenticated()
        && request.auth.uid == resource.data.parent_uid;
    }

    // ─────────────────────────────────────────
    // /curriculum/{docId}
    // Public textbook content — read-only for everyone
    // ─────────────────────────────────────────
    match /curriculum/{docId} {
      allow read: if true;      // Public curriculum content is open to all
      allow write: if false;    // Writes are only allowed via Admin SDK (backend)
    }

    // ─────────────────────────────────────────
    // CATCH-ALL: Deny everything not explicitly allowed above
    // ─────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
