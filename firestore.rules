rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Read-only access to curriculum data for all authenticated users
    match /levels/{levelId} {
      allow read: if request.auth != null;
      allow write: if false; // Only written by admin/backend
    }
    
    match /quizzes/{quizId} {
      allow read: if request.auth != null;
      allow delete: if request.auth != null && quizId.matches('quiz_' + request.auth.uid + '.*');
      allow create, update: if false; // Only written by admin/backend
    }

    match /lessons/{lessonId} {
      allow read: if request.auth != null;
      allow delete: if request.auth != null && lessonId.matches('lesson_' + request.auth.uid + '.*');
      allow create, update: if false; // Only written by admin/backend
    }

    // Users can only read and write their own profile and progress
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      match /progress/{progressId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}