{
  "expo": {
    "name": "sabaktutor",
    "slug": "sabaktutor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/sabaktutor-logo-removebg-preview.png",
    "scheme": "sabaktutor",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f7f9ff",
        "foregroundImage": "./assets/images/sabaktutor-logo-removebg-preview.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.sabak.tutor",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/sabaktutor-logo-removebg-preview.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/sabaktutor-logo-removebg-preview.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f7f9ff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8c74261b-74d8-44bd-ab6e-c133a8a67967"
      }
    }
  }
}
